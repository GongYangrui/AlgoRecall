DATABASE_URL=postgresql://postgres:postgres@localhost:5434/algorecall
COMPOSE_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/algorecall
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=algorecall
POSTGRES_HOST_PORT=55432

REDIS_URL=redis://localhost:6380
COMPOSE_REDIS_URL=redis://redis:6379
REDIS_HOST_PORT=6380

BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
TRUSTED_ORIGINS=http://localhost:3000
TRUSTED_PROXIES=127.0.0.1,::1
ADMIN_EMAILS=admin@algorecall.local

HOST_PORT=3000
APP_VERSION=dev
TZ=Asia/Shanghai
PG_POOL_MAX=10
PG_CONNECTION_TIMEOUT_MS=5000
PG_IDLE_TIMEOUT_MS=30000
PG_STATEMENT_TIMEOUT_MS=15000
PG_QUERY_TIMEOUT_MS=20000
LOG_RETENTION_DAYS=90
